@page "/"

<h1>Weight Control</h1>

<div class="weight-panel">
    <div class="button-group mb-3">
        <button class="btn btn-success" @onclick="WeightOn">Weight On</button>
        <button class="btn btn-danger ms-2" @onclick="WeightOff">Weight Off</button>
    </div>

    <div class="mt-3">
        <label for="weightInput" class="form-label">Weight</label>
        <input id="weightInput"
               type="text"
               class="form-control"
               value="@_weight"
               readonly />
    </div>
</div>

@code {
    private int _weight = 0;

    private void WeightOn()
    {
        _weight = 5;
    }

    private void WeightOff()
    {
        _weight = 0;
    }
}
