@page "/"

<h1>Weight Control</h1>

<div class="weight-panel">
    <button class="btn btn-primary" @onclick="ToggleWeight">Toggle Weight</button>

    <div class="mt-3">
        <label for="weightInput" class="form-label">Weight</label>
        <input id="weightInput"
               type="text"
               class="form-control"
               value="@_weight"
               readonly />
    </div>
</div>

@code {
    private int _weight = 0;

    private void ToggleWeight()
    {
        _weight = _weight == 0 ? 5 : 0;
    }
}
